@model Raktarkezelo.Models.Viewmodel.ChangeUsernameViewModel
@{ ViewData["Title"] = "Felhasználónév módosítása"; }
<style>
    .page { min-height:100vh; background:var(--bg-main); color:var(--text-primary); display:flex; font-family:Arial,Helvetica,sans-serif; }
    .content { flex:1; padding:40px; overflow-y:auto; }
    .form-card { background:var(--bg-card); border:1px solid var(--border-color); border-radius:12px; padding:32px; max-width:480px; margin: auto; }
    .form-label { color:var(--text-muted); font-size:14px; }
    .form-control { background:var(--bg-input); border:1px solid var(--border-input); color:var(--text-primary); border-radius:7px; }
    .form-control:focus { background:var(--bg-input); color:var(--text-primary); border-color:#0d6efd; box-shadow:none; }
    @@media(max-width:768px){ .page{flex-direction:column;} .content{padding:20px;} }
</style>
<div class="page">
    @await Html.PartialAsync("_Sidebar")
    <main class="content">
        <div class="form-card">
            <h2 class="mb-4">✏️ Felhasználónév módosítása</h2>
            <p class="text-muted small mb-4">Jelenlegi: <strong>@User.Identity?.Name</strong></p>
            <form asp-action="ChangeUsername" method="post">
                @Html.AntiForgeryToken()
                <div class="mb-4">
                    <label asp-for="NewUsername" class="form-label">Új felhasználónév</label>
                    <input asp-for="NewUsername" class="form-control" autofocus />
                    <span asp-validation-for="NewUsername" class="text-danger small"></span>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Mentés</button>
                    <a asp-action="Index" class="btn btn-secondary">Mégse</a>
                </div>
            </form>
        </div>
    </main>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
