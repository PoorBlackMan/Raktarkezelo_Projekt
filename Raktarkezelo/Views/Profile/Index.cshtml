@model Raktarkezelo.Models.Entities.Userinfo
@{
    ViewData["Title"] = "Profilom";
}
<style>
    .page { min-height:100vh; background:var(--bg-main); color:var(--text-primary); display:flex; font-family:Arial,Helvetica,sans-serif; }
    .content { flex:1; padding:40px; overflow-y:auto; }
    .profile-card { background:var(--bg-card); border:1px solid var(--border-color); border-radius:12px; padding:32px; max-width:560px; margin: auto;}
    .avatar-big { width:80px; height:80px; border-radius:50%; background:linear-gradient(135deg,#1e3a5f,#0d6efd); display:flex; align-items:center; justify-content:center; font-size:32px; font-weight:700; color:#fff; margin-bottom:20px; }
    .info-row { display:flex; justify-content:space-between; align-items:center; padding:12px 0; border-bottom:1px solid #2a2a2a; }
    .info-label { color:var(--text-muted); font-size:13px; }
    .info-value { font-weight:600; }
    .badge-role { padding:3px 12px; border-radius:4px; font-size:12px; font-weight:700; }
    .role-Manager { background:#6f42c1; color:#fff; }
    .role-Admin { background:#dc3545; color:#fff; }
    .role-User { background:#0d6efd; color:#fff; }
    @@media(max-width:768px){ .page{flex-direction:column;} .content{padding:20px;} }
</style>
<div class="page">
    @await Html.PartialAsync("_Sidebar")
    <main class="content">
        <div class="profile-card">
            @{ var initial = (User.Identity?.Name ?? "?")[0].ToString().ToUpper(); }
            <div class="avatar-big">@initial</div>
            <h2 class="mb-4">Profilom</h2>
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show mb-3">
                    @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            <div class="info-row"><span class="info-label">Felhasználónév</span><span class="info-value">@Model.Username</span></div>
            <div class="info-row"><span class="info-label">Email</span><span class="info-value">@Model.Email</span></div>
            <div class="info-row">
                <span class="info-label">Szerepkör</span>
                <span class="badge-role role-@Model.Role">@Model.Role</span>
            </div>
            <div class="info-row" style="border-bottom:none;">
                <span class="info-label">Fiók állapota</span>
                <span style="color:@(Model.IsActive ? "#4ade80" : "#f87171")">@(Model.IsActive ? "Aktív" : "Inaktív")</span>
            </div>
            <div class="d-flex gap-2 mt-4 flex-wrap">
                <a asp-action="ChangeUsername" class="btn btn-primary">✏️ Felhasználónév módosítása</a>
                <a asp-action="ChangePassword" class="btn btn-warning">🔑 Jelszó módosítása</a>
            </div>
        </div>
    </main>
</div>
