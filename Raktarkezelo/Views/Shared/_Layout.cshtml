<!DOCTYPE html>
<html lang="hu">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Raktarkezelo</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Raktarkezelo.styles.css" asp-append-version="true" />

    <style>
        html, body {
            height: 100%;
        }

        body {
            margin: 0;
            background-color: #0b0f14; /* globális sötét háttér */
            color: #e5e7eb;
            display: flex;
            flex-direction: column;
        }

        main {
            flex: 1;
        }

        footer {
            background: #0f172a;
            border-top: 1px solid rgba(255,255,255,0.08);
            color: #9ca3af;
            text-align: center;
            padding: 12px 0;
            font-size: 0.9rem;
        }
    </style>
</head>

<body>

    <!-- TELJES SZÉLESSÉGŰ WRAPPER -->
    <main>
        @RenderBody()
    </main>

    <footer>
        &copy; 2026 - Raktarkezelo
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>