@{
    ViewData["Title"] = "Adjustments";
}

<h1>Stock Adjustments</h1>

<form method="post">
    <div>
        <label>Product:</label>
        <select>
            <option>Product 1</option>
            <option>Product 2</option>
        </select>
    </div>

    <div>
        <label>New Quantity:</label>
        <input type="number" />
    </div>

    <div>
        <label>Reason:</label>
        <input type="text" />
    </div>

    <button type="submit">Apply</button>
</form>