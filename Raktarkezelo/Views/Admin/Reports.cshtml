@model List<Raktarkezelo.Models.Entities.StockTransactions>

@{
    ViewData["Title"] = "Reports";
}

<div class="container py-4">
    <h1>Reports</h1>

    <form method="get" class="row g-3 mb-4">
        <div class="col-md-4">
            <label class="form-label">From</label>
            <input type="date" name="fromDate" value="@ViewBag.FromDate" class="form-control" />
        </div>

        <div class="col-md-4">
            <label class="form-label">To</label>
            <input type="date" name="toDate" value="@ViewBag.ToDate" class="form-control" />
        </div>

        <div class="col-md-4 d-flex align-items-end">
            <button type="submit" class="btn btn-primary me-2">Filter</button>
            <a asp-action="Reports" class="btn btn-secondary">Reset</a>
        </div>
    </form>

    <table class="table table-dark table-striped table-bordered">
        <thead>
            <tr>
                <th>Product</th>
                <th>Type</th>
                <th>Quantity</th>
                <th>User</th>
                <th>Note</th>
                <th>Date</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Product.Name</td>
                    <td>@item.Type</td>
                    <td>@item.Quantity</td>
                    <td>@item.User.Username</td>
                    <td>@item.Note</td>
                    <td>@item.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                </tr>
            }
        </tbody>
    </table>

    <a asp-controller="Main" asp-action="Main" class="btn btn-secondary">Vissza</a>
</div>