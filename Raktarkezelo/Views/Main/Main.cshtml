@{
    ViewData["Title"] = "Main Page";
}

<style>
    .page {
        min-height: 100vh;
        background: #121212;
        color: #eaeaea;
        display: flex;
        font-family: Arial, Helvetica, sans-serif;
    }

    /* ===== SIDEBAR ===== */
    .sidebar {
        width: 240px;
        background: #161616;
        border-right: 1px solid rgba(255,255,255,0.15);
        padding: 20px 15px;
        flex: 0 0 240px;
    }

    .brand {
        font-size: 18px;
        font-weight: bold;
        margin-bottom: 20px;
    }

    .menu-title {
        font-size: 13px;
        color: #bdbdbd;
        margin-bottom: 10px;
    }

    .navlist {
        list-style: none;
        padding: 0;
        margin: 0;
    }

        .navlist li {
            margin-bottom: 14px;
        }

    .navlink {
        text-decoration: none;
        color: white;
        font-weight: 600;
        display: block;
    }

        .navlink:hover {
            text-decoration: underline;
        }

    .navhint {
        font-size: 12px;
        color: #aaaaaa;
    }

    /* ===== CONTENT ===== */
    .content {
        flex: 1;
        padding: 40px;
    }

    .wrap {
        max-width: 1000px;
        margin: 0 auto;
    }

    h1 {
        margin-bottom: 8px;
    }

    .subtitle {
        color: #bdbdbd;
        margin-bottom: 30px;
    }

    .panel {
        background: #1c1c1c;
        border: 1px solid #2a2a2a;
        border-radius: 6px;
        padding: 20px;
        margin-bottom: 20px;
    }

        .panel h2 {
            margin-top: 0;
            font-size: 18px;
            margin-bottom: 10px;
        }

        .panel p {
            margin: 0;
            color: #d0d0d0;
        }

    .devlist {
        margin: 0;
        padding-left: 18px;
    }

        .devlist li {
            margin-bottom: 6px;
        }

    /* ===== MOBILE ===== */
    @@media (max-width: 768px) {
        .page {
            flex-direction: column;
        }

        .sidebar {
            width: 100%;
            border-right: none;
            border-bottom: 1px solid rgba(255,255,255,0.15);
        }

        .content {
            padding: 20px;
        }
    }
</style>

<div class="page">

    <aside class="sidebar">
        <div class="brand">Raktárkezelő</div>
        <div class="menu-title">Menu</div>

        <ul class="navlist">
            <li>
                <a asp-controller="Main" asp-action="Products" class="navlink">Products</a>
                <div class="navhint">Product management</div>
            </li>

            <li>
                <a asp-controller="Admin" asp-action="Inbound" class="navlink">Inbound</a>
                <div class="navhint">Stock entry</div>
            </li>

            <li>
                <a asp-controller="Admin" asp-action="Outbound" class="navlink">Outbound</a>
                <div class="navhint">Stock exit</div>
            </li>

            <li>
                <a asp-controller="Admin" asp-action="Adjustments" class="navlink">Adjustments</a>
                <div class="navhint">Stock correction</div>
            </li>

            <li>
                <a asp-controller="Admin" asp-action="Reports" class="navlink">Reports</a>
                <div class="navhint">Statistics & lists</div>
            </li>

            <li>
                <a asp-controller="Manager" asp-action="Users" class="navlink">Users</a>
                <div class="navhint">User management</div>
            </li>
        </ul>
    </aside>

    <!-- ===== CONTENT ===== -->
    <main class="content">
        <div class="wrap">

            <h1>Main Page</h1>
            <div class="subtitle">
                Select a module from the left menu.
            </div>

            <div class="panel">
                <h2>Welcome</h2>
                <p>Welcome to the warehouse management system.</p>
            </div>

            <div class="panel">
                <h2>About</h2>
                <p>
                    This application was created to manage stock movements clearly and efficiently.
                    Products, inbound and outbound transactions are handled in one place.
                </p>
            </div>

            <div class="panel">
                <h2>Developers</h2>
                <ul class="devlist">
                    <li><strong>Mátyásházi Milán</strong> — Database</li>
                    <li><strong>Molnár Edvárd</strong> — Frontend</li>
                    <li><strong>Barkóczi Dávid</strong> — Backend</li>
                </ul>
            </div>

        </div>
    </main>

</div>