@model List<Raktarkezelo.Models.Entities.Products>

@{
    ViewData["Title"] = "Main Page";
    var lowStockProducts = Model.Where(p => p.Stock <= p.MinStock).ToList();
}

<style>
    .page {
        min-height: 100vh;
        background: #121212;
        color: #eaeaea;
        display: flex;
        font-family: Arial, Helvetica, sans-serif;
    }

    .sidebar {
        width: 240px;
        background: #161616;
        border-right: 1px solid rgba(255,255,255,0.15);
        padding: 20px 15px;
        flex: 0 0 240px;
    }

    .brand {
        font-size: 18px;
        font-weight: bold;
        margin-bottom: 20px;
    }

    .menu-title {
        font-size: 13px;
        color: #bdbdbd;
        margin-bottom: 10px;
    }

    .navlist {
        list-style: none;
        padding: 0;
        margin: 0;
    }

        .navlist li {
            margin-bottom: 14px;
        }

    .navlink {
        text-decoration: none;
        color: white;
        font-weight: 600;
        display: block;
    }

    .navhint {
        font-size: 12px;
        color: #aaaaaa;
    }

    .content {
        flex: 1;
        padding: 40px;
    }

    .wrap {
        max-width: 1100px;
        margin: 0 auto;
    }

    .subtitle {
        color: #bdbdbd;
        margin-bottom: 30px;
    }

    .panel {
        background: #1c1c1c;
        border: 1px solid #2a2a2a;
        border-radius: 10px;
        padding: 20px;
        margin-bottom: 20px;
    }

    .grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        margin-bottom: 20px;
    }

    .stat-box {
        background: #1c1c1c;
        border: 1px solid #2a2a2a;
        border-radius: 10px;
        padding: 20px;
    }

    .stat-number {
        font-size: 28px;
        font-weight: bold;
    }

    .warning-table {
        width: 100%;
        border-collapse: collapse;
    }

        .warning-table th,
        .warning-table td {
            border: 1px solid #333;
            padding: 10px;
        }

    @@media (max-width: 768px) {
        .page {
            flex-direction: column;
        }

        .sidebar {
            width: 100%;
            border-right: none;
            border-bottom: 1px solid rgba(255,255,255,0.15);
        }

        .content {
            padding: 20px;
        }

        .grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="page">
    <aside class="sidebar">
        <div class="brand">Raktárkezelő</div>
        <div class="menu-title">Menu</div>

        <ul class="navlist">
            <li>
                <a asp-controller="Main" asp-action="Products" class="navlink">Products</a>
                <div class="navhint">Product management</div>
            </li>

            @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
            {
                <li>
                    <a asp-controller="Admin" asp-action="Inbound" class="navlink">Inbound</a>
                    <div class="navhint">Stock entry</div>
                </li>

                <li>
                    <a asp-controller="Admin" asp-action="Outbound" class="navlink">Outbound</a>
                    <div class="navhint">Stock exit</div>
                </li>

                <li>
                    <a asp-controller="Admin" asp-action="Adjustments" class="navlink">Adjustments</a>
                    <div class="navhint">Stock correction</div>
                </li>

                <li>
                    <a asp-controller="Admin" asp-action="Reports" class="navlink">Reports</a>
                    <div class="navhint">Statistics & lists</div>
                </li>
            }

            @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
            {
                <li>
                    <a asp-controller="Manager" asp-action="Users" class="navlink">Users</a>
                    <div class="navhint">User management</div>
                </li>
            }

            <li>
                <a asp-controller="RegLog" asp-action="Logout" class="navlink">Logout</a>
                <div class="navhint">Kilépés a rendszerből</div>
            </li>
        </ul>
    </aside>

    <main class="content">
        <div class="wrap">
            <h1>Main Page</h1>
            <div class="subtitle">Üdv a raktárkezelő rendszerben.</div>

            <div class="grid">
                <div class="stat-box">
                    <div>Összes termék</div>
                    <div class="stat-number">@Model.Count</div>
                </div>
                <div class="stat-box">
                    <div>Alacsony készlet</div>
                    <div class="stat-number">@lowStockProducts.Count</div>
                </div>
                <div class="stat-box">
                    <div>Bejelentkezve</div>
                    <div class="stat-number">@User.Identity?.Name</div>
                </div>
            </div>

            <div class="panel">
                <h2>Alacsony készlet figyelés</h2>

                @if (lowStockProducts.Any())
                {
                    <table class="warning-table">
                        <thead>
                            <tr>
                                <th>Termék</th>
                                <th>Kategória</th>
                                <th>Készlet</th>
                                <th>Minimum</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in lowStockProducts)
                            {
                                <tr>
                                    <td>@item.Name</td>
                                    <td>@item.Category</td>
                                    <td>@item.Stock</td>
                                    <td>@item.MinStock</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p>Nincs minimum alá csökkent termék.</p>
                }
            </div>

            <div class="panel">
                <h2>About</h2>
                <p>
                    Ez az alkalmazás a készletmozgások átlátható kezelésére készült.
                    Egy helyen kezeli a termékeket, bejövő és kimenő mozgásokat, korrekciókat és riportokat.
                </p>
            </div>
        </div>
    </main>
</div>