@model List<Raktarkezelo.Models.Entities.Products>

@{
    ViewData["Title"] = "Products";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Products</h1>

        @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
        {
            <a asp-action="CreateProduct" class="btn btn-primary">+ Add New Product</a>
        }
    </div>

    <table class="table table-dark table-striped table-bordered align-middle">
        <thead>
            <tr>
                <th>Name</th>
                <th>Category</th>
                <th>Stock</th>
                <th>Min Stock</th>
                <th>Note</th>
                @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                {
                    <th>Actions</th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr class="@(item.Stock <= item.MinStock ? "table-warning" : "")">
                    <td>@item.Name</td>
                    <td>@item.Category</td>
                    <td>@item.Stock</td>
                    <td>@item.MinStock</td>
                    <td>@item.Note</td>

                    @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                    {
                        <td>
                            <a asp-action="EditProduct" asp-route-id="@item.ProductId" class="btn btn-sm btn-warning">Edit</a>

                            <form asp-action="DeleteProduct" asp-route-id="@item.ProductId" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Biztos törlöd?')">Delete</button>
                            </form>
                        </td>
                    }
                </tr>
            }
        </tbody>
    </table>

    <a asp-action="Main" class="btn btn-secondary">Vissza</a>
</div>